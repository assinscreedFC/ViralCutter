{
    "font": "Montserrat-ExtraBold",
    "base_size": 18,
    "base_color": "&H00FFFFFF&",
    "highlight_color": "&H0000FF00&",
    "outline_color": "&H00000000&",
    "outline_thickness": 3,
    "shadow_color": "&H00000000&",
    "shadow_size": 1,
    "vertical_position": 200,
    "alignment": 2,
    "bold": 1,
    "italic": 0,
    "underline": 0,
    "strikeout": 0,
    "border_style": 1,
    "words_per_block": 5,
    "gap_limit": 0.5,
    "mode": "highlight",
    "highlight_size": 16,
    "remove_punctuation": true,
    "uppercase": 1
}