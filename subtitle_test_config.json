{
    "font": "Montserrat-ExtraBold",
    "base_size": 20,
    "base_color": "&H00FFFFFF&",
    "highlight_color": "&H0000D7FF&",
    "outline_color": "&HFF000000&",
    "outline_thickness": 3,
    "shadow_color": "&H00000000&",
    "shadow_size": 2,
    "bold": 1,
    "italic": 0,
    "uppercase": 1,
    "vertical_position": 180,
    "alignment": 2,
    "highlight_size": 24,
    "words_per_block": 4,
    "gap_limit": 0.25,
    "mode": "highlight",
    "underline": 0,
    "strikeout": 0,
    "border_style": 1,
    "remove_punctuation": true,
    "animation": "bounce"
}
